# ─── Backend Environment Variables ────────────────────────────────────────────
# Copy this file to .env and fill in the values for your environment.
# Required values are marked with (REQUIRED).

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=5001

# ─── MongoDB (REQUIRED) ──────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=admin_mainbeta

# ─── Authentication ──────────────────────────────────────────────────────────
# IMPORTANT: Change this in production!
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# ─── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (optional, patterns are built-in)
ALLOWED_ORIGINS=https://admin.yourdomain.com,https://store.yourdomain.com

# ─── Multi-tenancy ──────────────────────────────────────────────────────────
PRIMARY_DOMAIN=yourdomain.com
COOKIE_DOMAIN=.yourdomain.com

# ─── App URLs ────────────────────────────────────────────────────────────────
ADMIN_URL=https://admin.yourdomain.com
STOREFRONT_URL=https://store.yourdomain.com

# ─── File Uploads ────────────────────────────────────────────────────────────
# Local upload directory (non-Docker)
UPLOAD_DIR=./uploads
# Docker shared volume (set automatically in docker-compose.yml)
# SHARED_UPLOADS_DIR=/var/www/uploads

# ─── Cloudflare R2 (optional) ───────────────────────────────────────────────
# CF_ACCOUNT_ID=
# CF_R2_ACCESS_KEY=
# CF_R2_SECRET_KEY=
# CF_R2_BUCKET_NAME=
# CF_R2_PUBLIC_URL=

# ─── Redis (optional) ───────────────────────────────────────────────────────
# REDIS_URL=redis://localhost:6379

# ─── Google AI (optional) ───────────────────────────────────────────────────
# GEMINI_API_KEY=
